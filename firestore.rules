rules_version = '2';
// Полный набор правил для Смарт Задачник + ТЗ + публикации.
// Задеплой в Firebase: консоль → Firestore → Правила → вставить целиком → Опубликовать.

service cloud.firestore {
  match /databases/{database}/documents {

    // Профили (в т.ч. чтение ников участников, флеш-сигнал на чужой документ)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Команды
    match /teams/{teamId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.members;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members;
      allow update, delete: if request.auth != null
        && request.auth.uid in resource.data.members;
    }

    // Задачи и заметки
    match /tasks/{taskId} {
      allow read, create, update, delete: if request.auth != null;
    }

    // Редактор ТЗ (tz.html)
    match /tzSpecs/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Публикация по ссылке (tz-view.html) + комментарии гостей
    match /tzShares/{shareId} {
      allow get: if true;
      allow list: if false;

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerUserId
        && shareId.size() >= 16
        && request.resource.data.keys().hasAll(['ownerUserId', 'tzSpecId', 'allowComments', 'snapshot', 'createdAt']);

      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.ownerUserId;

      match /comments/{commentId} {
        allow get, list: if true;

        allow create: if get(/databases/$(database)/documents/tzShares/$(shareId)).data.allowComments == true
          && request.resource.data.keys().hasAll(['text', 'createdAt'])
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() < 8000
          && (!request.resource.data.keys().hasAny(['authorName'])
              || request.resource.data.authorName == null
              || (request.resource.data.authorName is string && request.resource.data.authorName.size() < 120));

        allow update: if request.auth != null
          && get(/databases/$(database)/documents/tzShares/$(shareId)).data.ownerUserId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ownerReply', 'ownerReplyAt', 'resolved']);

        allow delete: if request.auth != null
          && get(/databases/$(database)/documents/tzShares/$(shareId)).data.ownerUserId == request.auth.uid;
      }
    }
  }
}
